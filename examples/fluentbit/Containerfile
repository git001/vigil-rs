# Stage 1 — build vigild and vigil as static musl binaries
FROM rust:alpine AS vigil-builder
RUN apk add --no-cache musl-dev
WORKDIR /vigil-rs
COPY Cargo.toml Cargo.lock ./
COPY crates/ crates/
RUN cargo build --release --bin vigild --bin vigil

# Stage 2 — final image: Fluent Bit (debug variant includes shell + curl)
FROM fluent/fluent-bit:4.2-debug
COPY --from=vigil-builder /vigil-rs/target/release/vigild /usr/local/bin/vigild
COPY --from=vigil-builder /vigil-rs/target/release/vigil  /usr/local/bin/vigil
COPY examples/fluentbit/fluent-bit.conf /fluent-bit/etc/vigil-fluent-bit.conf
COPY examples/fluentbit/layers/ /etc/vigil/layers/
RUN mkdir -p /run/vigil

ENTRYPOINT ["/usr/local/bin/vigild", \
    "--layers-dir", "/etc/vigil/layers", \
    "--socket",     "/run/vigil/vigild.sock"]
