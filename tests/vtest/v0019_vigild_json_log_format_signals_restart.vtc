vtest "vigild: --log-format json, SIGHUP/SIGUSR1/SIGUSR2 forwarding, and daemon restart"

# ---------------------------------------------------------------------------
# Part 1: --log-format json
# ---------------------------------------------------------------------------
# Start vigild with JSON log format and verify it boots and serves requests.

shell { mkdir -p ${tmpdir}/layers }

shell {
	${vigild} \
		--layers-dir ${tmpdir}/layers \
		--socket     ${tmpdir}/vigild.sock \
		--log-format json \
		>> ${tmpdir}/vigild_json.log 2>&1 < /dev/null &
	echo $! > ${tmpdir}/vigild.pid
}

shell {
	for i in $(seq 1 50); do
		test -S ${tmpdir}/vigild.sock && break
		sleep 0.1
	done
	test -S ${tmpdir}/vigild.sock
}

# Verify the daemon responds normally.
client c1 -connect ${tmpdir}/vigild.sock {
	txreq -method GET -url /v1/system-info -hdr "Host: localhost"
	rxresp
	expect resp.status == 200
} -run

# Verify log output is JSON (tracing-subscriber json format includes "level":).
shell {
	head -3 ${tmpdir}/vigild_json.log | grep -q '"level"'
}

# ---------------------------------------------------------------------------
# Part 2: SIGHUP / SIGUSR1 / SIGUSR2 signal forwarding
# ---------------------------------------------------------------------------
# Add a long-running service so that vigild has a child process to forward to.
# We only need to exercise the select{} branches — the service command is kept
# deliberately simple (pure /bin/sh busy-wait, no shell-variable expansion in
# the vtc heredoc).

shell {
	cat > ${tmpdir}/layers/signal-sink.yaml <<'YAML'
services:
  signal-sink:
    command: "/bin/sh -c 'while true; do sleep 1; done'"
    startup: enabled
YAML
	${vigil} --socket ${tmpdir}/vigild.sock replan
}

# Wait for the service to start.
shell {
	for i in $(seq 1 50); do
		${vigil} --socket ${tmpdir}/vigild.sock services list \
			| grep -q 'signal-sink' && break
		sleep 0.1
	done
}

shell { sleep 0.3 }

# Send SIGHUP to vigild → exercises the SIGHUP select branch (forward to services).
shell { kill -HUP  $(cat ${tmpdir}/vigild.pid) }
shell { sleep 0.1 }
# SIGUSR1
shell { kill -USR1 $(cat ${tmpdir}/vigild.pid) }
shell { sleep 0.1 }
# SIGUSR2
shell { kill -USR2 $(cat ${tmpdir}/vigild.pid) }
shell { sleep 0.2 }

# vigild must still be running and responding after the three signals.
client c2 -connect ${tmpdir}/vigild.sock {
	txreq -method GET -url /v1/system-info -hdr "Host: localhost"
	rxresp
	expect resp.status == 200
} -run

# ---------------------------------------------------------------------------
# Part 3: DaemonAction::Restart (re-exec path in main.rs)
# ---------------------------------------------------------------------------
# POST /v1/vigild with action=restart causes vigild to re-exec itself.
# The same PID continues as a new vigild instance (exec replaces the image).

shell { rm -f ${tmpdir}/layers/signal-sink.yaml }

client c3 -connect ${tmpdir}/vigild.sock {
	txreq -method POST -url /v1/vigild -hdr "Host: localhost" \
		-hdr "Content-Type: application/json" \
		-body "{\"action\":\"restart\"}"
	rxresp
	expect resp.status == 200
} -run

# Wait for the socket to disappear, then for the re-exec'd daemon to recreate it.
shell {
	for i in $(seq 1 30); do
		test -S ${tmpdir}/vigild.sock || break
		sleep 0.1
	done
	for i in $(seq 1 60); do
		test -S ${tmpdir}/vigild.sock && break
		sleep 0.1
	done
	test -S ${tmpdir}/vigild.sock
}

# The re-exec'd vigild must serve requests normally.
client c4 -connect ${tmpdir}/vigild.sock {
	txreq -method GET -url /v1/system-info -hdr "Host: localhost"
	rxresp
	expect resp.status == 200
} -run

# Tear down.
shell {
	kill $(cat ${tmpdir}/vigild.pid) 2>/dev/null || true
	for i in $(seq 1 30); do
		kill -0 $(cat ${tmpdir}/vigild.pid) 2>/dev/null || break
		sleep 0.1
	done
}
