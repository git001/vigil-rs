vtest "POST /v1/vigild with action=stop shuts down the daemon"

shell { mkdir -p ${tmpdir}/layers }

process p1 "${vigild} --layers-dir ${tmpdir}/layers --socket ${tmpdir}/vigild.sock" -start

shell {
	for i in $(seq 1 50); do
		test -S ${tmpdir}/vigild.sock && break
		sleep 0.1
	done
	test -S ${tmpdir}/vigild.sock
}

# Send stop — the daemon accepts and begins shutdown
client c1 -connect ${tmpdir}/vigild.sock {
	txreq -method POST -url /v1/vigild -hdr "Host: localhost" \
		-hdr "Content-Type: application/json" \
		-body "{\"action\":\"stop\"}"
	rxresp
	expect resp.status == 200
} -run

# Wait for daemon to finish; it should exit cleanly (exit code 0)
process p1 -wait
